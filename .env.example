# ─────────────────────────────────────────────────────────────────────────────
# GmailSaaS Bot — Environment Configuration
# Copy this file to .env and fill in all values before running the bot.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Telegram ─────────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Bot username WITHOUT the @ (used in OAuth success page links)
BOT_USERNAME=your_bot_username

# Bot display name (shown in messages)
BOT_NAME=GmailSaaS Bot

# Comma-separated Telegram user IDs of admins (no spaces)
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=your_telegram_id_here

# Comma-separated channel usernames users must join before using the bot
# Leave blank to disable force-join: REQUIRED_CHANNELS=
# Example: REQUIRED_CHANNELS=@mychannel,@mysecondchannel
REQUIRED_CHANNELS=

# Support contact shown in help message
SUPPORT_USERNAME=@zionixportal

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite (default, good for development and small deployments):
DATABASE_URL=sqlite+aiosqlite:///./data.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gmailsaas

# ─── Redis ────────────────────────────────────────────────────────────────────

# Redis connection URL (required for OAuth state storage and RQ worker)
REDIS_URL=redis://localhost:6379/0

# ─── Encryption ───────────────────────────────────────────────────────────────

# Fernet symmetric key for encrypting Gmail refresh tokens.
# Generate one with: python generate_key.py
# ⚠️  Keep this secret and NEVER change it after first use — it will
#     invalidate all stored tokens.
ENCRYPTION_KEY=your_fernet_key_here_generate_with_generate_key.py

# ─── Google OAuth ─────────────────────────────────────────────────────────────

# From Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID of type "Web application"
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# The redirect URI registered in Google Cloud Console.
# For local dev: http://localhost:8080/oauth/callback
# For production: https://yourdomain.com/oauth/callback
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback

# ─── OAuth callback server (Flask) ───────────────────────────────────────────

OAUTH_SERVER_HOST=0.0.0.0
OAUTH_SERVER_PORT=8080

# Random secret for Flask session signing
FLASK_SECRET_KEY=change_this_to_a_random_string_at_least_32_chars

# ─── Payment ──────────────────────────────────────────────────────────────────

# Crypto wallet address shown to users
PAYMENT_CRYPTO_ADDRESS=YOUR_USDT_OR_BTC_WALLET_ADDRESS

# UPI ID shown to users (for Indian users)
PAYMENT_UPI_ID=yourname@upi

# Note shown below payment details
PAYMENT_NOTE=Please include your Telegram User ID in the payment memo/note.

# ─── Credit system ────────────────────────────────────────────────────────────

# Credits deducted when linking one Gmail account
CREDITS_PER_ACCOUNT=1

# New users start with this many credits
NEW_USER_CREDITS=0

# Default daily inbox fetch limit per user
DEFAULT_DAILY_LIMIT=20

# ─── Logging ──────────────────────────────────────────────────────────────────

LOG_FILE=logs/bot.log
LOG_LEVEL=INFO
